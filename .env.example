# app
APP_ENV=main
# cloudflared-tunnel
TUNNEL_TOKEN=
# nginx PORTS
NGINX_PORT_WP_APP=8080
NGINX_PORT_LARAVEL_APP=80
# nginx.conf fastcgi_pass proxy_pass
# laravel octan
LISTEN=80
SERVER_NAME=localhost
# PROXY_PASS=http://laravel-octane-alpine-ncc-prod:2000
# app path VOLUMES_PROJECT_APP_PATH
APP_PATH=/var/www/html
# db wp app
WP_APP_PATH=/var/www/html/wp-app
# laravel-app
LARAVEL_APP_PATH=/var/www/html/laravel-app
# git packages-ncc
PACKAGES_NCC_APP_PATH=/var/www/html/packages-ncc
# db wp app => wp-cli use WP_PATH="${WP_APP_PATH}"
WP_PATH=/var/www/html/wp-app
DB_HOST=mariadb-alpine-ncc
DB_USER=dev_user
DB_PASSWORD=cong12345
DB_NAME=dev_database
DB_CHARSET=utf8mb4
DB_COLLATE=utf8mb4_unicode_ci
# site url
WP_URL=http://localhost:8080
WP_TITLE="DEV WP APP"
WP_ADMIN=admin
WP_ADMIN_PASSWORD=cong12345
WP_ADMIN_EMAIL=dev@gmail.com
# wp-app.conf
WP_APP_CONF_LISTEN=8080
WP_APP_CONF_SERVER_NAME=localhost
# WP_APP_CONF_FASTCGI_PASS=php-fpm-alpine-ncc-prod:9000
# laravel dev ssh authorized_keys
LARAVEL_DEV_AUTHORIZED_KEY=
# laravel php-fpm conf
LARAVEL_PHP_FPM_CONF_LISTEN=8888
LARAVEL_PHP_FPM_CONF_SERVER_NAME=localhost
# LARAVEL_APP_DEV_CONF_FASTCGI_PASS=php-fpm-alpine-ncc-dev:9000